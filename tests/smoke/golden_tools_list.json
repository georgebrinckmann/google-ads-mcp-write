            "description": "Numeric id of the campaign.",
            "type": "string"
          },
          "customer_id": {
            "description": "The customer account id.",
            "type": "string"
          },
          "image_url": {
            "description": "Public URL of the image (e.g. from the client's site).",
            "type": "string"
          },
          "square": {
            "default": false,
            "description": "True for 1:1 square marketing image, False for landscape.",
            "type": "boolean"
          }
        },
        "required": [
          "customer_id",
          "campaign_id",
          "image_url",
          "asset_name"
        ],
        "type": "object"
      },
      "name": "mutate_upload_image_from_url",
      "outputSchema": {
        "additionalProperties": true,
        "type": "object"
      }
