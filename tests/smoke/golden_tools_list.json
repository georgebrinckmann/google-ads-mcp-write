    {
      "_meta": {
        "fastmcp": {
          "tags": []
        }
      },
      "description": "Creates a Search campaign. ALWAYS created PAUSED (safety guardrail).\n\nUses Maximize Clicks (TARGET_SPEND) bidding, optionally with a max CPC\nceiling \u2014 the right strategy for accounts without conversion history.\nSearch partners and Display network are disabled by default.",
      "inputSchema": {
        "additionalProperties": false,
        "properties": {
          "budget_resource_name": {
            "description": "Resource name returned by create_campaign_budget.",
            "type": "string"
          },
          "customer_id": {
            "description": "The customer account id.",
            "type": "string"
          },
          "geo_ids": {
            "default": [
              2076
            ],
            "description": "Geo target constant ids. Default [2076] = Brazil.",
            "items": {
              "type": "integer"
            },
            "type": "array"
          },
          "language_ids": {
            "default": [
              1014
            ],
            "description": "Language constant ids. Default [1014] = Portuguese.",
            "items": {
              "type": "integer"
            },
            "type": "array"
          },
          "max_cpc": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "Optional CPC bid ceiling in account currency."
          },
          "name": {
            "description": "Campaign name.",
            "type": "string"
          }
        },
        "required": [
          "customer_id",
          "name",
          "budget_resource_name"
        ],
        "type": "object"
      },
      "name": "mutate_create_search_campaign",
      "outputSchema": {
        "additionalProperties": true,
        "type": "object"
      }
    },
    {
      "_meta": {
        "fastmcp": {
          "tags": []
        }
      },
      "description": "Creates sitelink assets and links them to a campaign.\n\nRULE: every sitelink must be about the SAME service this campaign\nadvertises (pricing, portfolio, process, quote, testimonials, FAQ of\nTHAT service). NEVER link to a different service of the business \u2014\ne.g. a \"Google Ads Management\" sitelink on a \"Website Creation\"\ncampaign is forbidden. Do not reuse existing assets from other\nservices. Provide exactly 6 sitelinks with both description lines.",
      "inputSchema": {
        "additionalProperties": false,
        "properties": {
          "campaign_id": {
            "description": "Numeric id of the campaign.",
            "type": "string"
          },
          "customer_id": {
            "description": "The customer account id.",
            "type": "string"
          },
          "sitelinks": {
            "description": "List of {\"text\",\"description1\",\"description2\",\"url\"}.\ntext <= 25 chars, descriptions <= 35 chars each.",
            "items": {
              "additionalProperties": {
                "type": "string"
              },
              "type": "object"
            },
            "type": "array"
          }
        },
        "required": [
          "customer_id",
          "campaign_id",
          "sitelinks"
        ],
        "type": "object"
      },
      "name": "mutate_create_sitelinks",
      "outputSchema": {
        "additionalProperties": true,
        "type": "object"
      }
    },
    {
      "_meta": {
        "fastmcp": {
          "tags": []
        }
      },
      "description": "Creates a structured snippet asset and links it to a campaign.",
